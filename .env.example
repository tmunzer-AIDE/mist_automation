# Application
APP_NAME=Mist Automation & Backup
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# Security - IMPORTANT: Change these in production!
SECRET_KEY=changeme-generate-secure-random-key-at-least-64-chars-long
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"

# API
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:4200,http://localhost:8080

# Password Policy
MIN_PASSWORD_LENGTH=8
REQUIRE_UPPERCASE=true
REQUIRE_LOWERCASE=true
REQUIRE_DIGITS=true
REQUIRE_SPECIAL_CHARS=false

# Session Management
ACCESS_TOKEN_EXPIRE_HOURS=24
REFRESH_TOKEN_EXPIRE_DAYS=30
MAX_CONCURRENT_SESSIONS=5
DEVICE_TRUST_DAYS=30

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=mist_automation
MONGODB_MIN_POOL_SIZE=10
MONGODB_MAX_POOL_SIZE=100

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# Mist API Configuration
MIST_API_TOKEN=
MIST_ORG_ID=
MIST_CLOUD_REGION=global
MIST_API_TIMEOUT=30
MIST_API_MAX_RETRIES=3

# Workflow Execution
MAX_CONCURRENT_WORKFLOWS=10
WORKFLOW_DEFAULT_TIMEOUT=300
WORKFLOW_MAX_TIMEOUT=3600
WEBHOOK_DEDUP_TTL=300

# Background Tasks (Celery)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_FULL_SCHEDULE_CRON=0 2 * * *
BACKUP_RETENTION_DAYS=90
BACKUP_GIT_ENABLED=false
BACKUP_GIT_REPO_URL=
BACKUP_GIT_BRANCH=main
BACKUP_GIT_AUTHOR_NAME=Mist Automation
BACKUP_GIT_AUTHOR_EMAIL=automation@example.com

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=

# External Integrations (Optional)
SLACK_WEBHOOK_URL=
SERVICENOW_INSTANCE_URL=
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=
PAGERDUTY_INTEGRATION_KEY=
